# Copy this file to `.env` and fill in real values.
# The `.env` file is git-ignored and must NEVER be committed.

# Supabase project — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-or-publishable-key

# Google Maps Platform key with Places API (New), Routes API,
# Maps SDK for Android, and Maps JavaScript API enabled.
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Razorpay — Dashboard → Settings → API Keys (use test key locally)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
